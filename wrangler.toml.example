name = "katelyatv"
compatibility_date = "2026-05-11"
compatibility_flags = ["nodejs_compat"]
pages_build_output_dir = ".vercel/output/static"

# 这个文件只提供 D1 和 Cron 的最小模板。
# 真正启用前，请把下面的数据库名、数据库 ID 和 Cron 时间改成你自己的值。

[[d1_databases]]
binding = "DB"
database_name = "replace-with-your-d1-name"
database_id = "replace-with-your-d1-id"
migrations_dir = "migrations"

[vars]
NEXT_PUBLIC_STORAGE_TYPE = "d1"
SOURCE_RANKING_ENABLED = "true"
NEXT_PUBLIC_SOURCE_RANKING_ENABLED = "true"
SOURCE_RANKING_FALLBACK_TO_LIVE = "true"
SOURCE_RANKING_CRON_ENABLED = "true"
AI_DAILY_LIMIT_PER_USER = "20"
AI_DAILY_LIMIT_PER_IP = "60"
AI_DAILY_LIMIT_GLOBAL = "500"
AI_GROUP_DAILY_LIMIT_PER_USER = "100"
AI_GROUP_DAILY_LIMIT_PER_IP = "300"
AI_GROUP_DAILY_LIMIT_GLOBAL = "2500"
# PASSWORD 和 AUTH_SIGNING_SECRET 需要作为 secret 单独配置，不要写入仓库
USERNAME = "admin"
